# Raiz do monorepo leve (app em web/)
.DS_Store
Thumbs.db

# Docker Compose na VPS (não commitar segredos)
.env
.env.*
!.env.example

# Volume SQLite na raiz (ficheiros reais só na máquina / cópia manual)
/data/*.db
/data/*.db-wal
/data/*.db-shm

# Proteções explícitas da app web (defesa extra)
/web/.env
/web/.env.*
!/web/.env.example
/web/.next/
/web/node_modules/
/web/data/*.db
/web/data/*.db-wal
/web/data/*.db-shm
