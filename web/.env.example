# URL pública do backend na VPS (sem barra no fim). Vazio = mesma origem que a página.
# NEXT_PUBLIC_API_BASE_URL=https://api.seudominio.com

# Origens exatas do PWA/front (CORS em /api/*). Separadas por vírgula.
# Ex.: página em https://app.seudominio.com e API em https://api.seudominio.com
# ALLOWED_ORIGINS=https://app.seudominio.com

# Web Push (VAPID). Gere com: npm run push:keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:teu-email@exemplo.com
# PUSH_TEST_SECRET=
# CRON_SECRET=
# (Autorização POST /api/cron/reminders e chamadas internas do agendador; se vazio, usa PUSH_TEST_SECRET.)
# INTERNAL_CRON_HOST=127.0.0.1
# (Só no servidor — nunca expor no browser.)

# Lembretes automáticos (cron interno ao rodar `next start` na VPS).
# Por omissão: ligado em produção se VAPID estiver definido; em desenvolvimento fica desligado.
# REMINDER_PUSH_ENABLED=1
# REMINDER_PUSH_INTERVAL_MS=7200000
# REMINDER_PUSH_FIRST_RUN_HOUR=8
# (Âncora do agendamento em hora local do servidor: 8 => 08:00, depois +2h, +2h...)
